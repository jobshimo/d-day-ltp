{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "bundler",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["ES2022", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "application-course-store": [
        "libs/application/course-store/src/index.ts"
      ],
      "application-drill-store": ["libs/application/drill-store/src/index.ts"],
      "content": ["libs/content/src/index.ts"],
      "content-schema": ["libs/shared/content-schema/src/index.ts"],
      "domain-course": ["libs/domain/course/src/index.ts"],
      "domain-drill": ["libs/domain/drill/src/index.ts"],
      "domain-progress": ["libs/domain/progress/src/index.ts"],
      "infrastructure-idb-adapter": [
        "libs/infrastructure/idb-adapter/src/index.ts"
      ],
      "ui-board-renderer": ["libs/ui/board-renderer/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp", "d-day"]
}
