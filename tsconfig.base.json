{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "bundler",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["ES2022", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "content-schema": ["libs/shared/content-schema/src/index.ts"],
      "domain-course": ["libs/domain/course/src/index.ts"],
      "domain-progress": ["libs/domain/progress/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp", "d-day"]
}
